#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    default_album_art_path: None,
    format_tag_separator: " | ",
    browser_column_widths: [20, 38, 42],
    preview_label_style: (fg: "#7aa2f7"),
    preview_metadata_group_style: (fg: "#7aa2f7", modifiers: "Bold"),
    highlighted_item_style: (fg: "#d6b11a", modifiers: "Bold"),
    current_item_style: (fg: "black", bg: "#d6b11a", modifiers: "Bold"),
    borders_style: (fg: "#646464"),
    highlight_border_style: (fg: "#646464"),
    symbols: (
        song: " ",
        dir: " ",
        playlist: " ",
        marker: " ",
        ellipsis: "...",
        song_style: None,
        dir_style: None,
        playlist_style: None,
    ),
    progress_bar: (
        symbols: ["[", "-", ">", " ", "]"],
        track_style: None,
        elapsed_style: (fg: "#d6b11a"),
        thumb_style: (fg: "#d6b11a"),
        use_track_when_empty: true,
    ),
    scrollbar: (
        symbols: ["", "", "", ""],
        track_style: (),
        ends_style: (),
        thumb_style: (fg: "#d6b11a"),
    ),
    tab_bar: (
        active_style: (fg: "black", bg: "#d6b11a", modifiers: "Bold"),
        inactive_style: (),
    ),
    browser_song_format: [
        (
            kind: Group([
                (kind: Property(Title)),
                (kind: Text(" - ")),
                (kind: Property(Artist)),
            ]),
            default: (kind: Property(Filename))
        ),
    ],
    song_table_format: [
        (
            prop: (kind: Property(Title),
                default: (kind: Text("Unknown"))
            ),
            label_prop: (kind: Text("Title")),
            width: "50%",
        ),
        (
            prop: (kind: Property(Artist),
                default: (kind: Text("Unknown"))
            ),
            label_prop: (kind: Text("Artist")),
            width: "40%",
        ),
        (
            prop: (kind: Property(Duration),
                default: (kind: Text("-"))
            ),
            label_prop: (kind: Text("Duration")),
            width: "10%",
            alignment: Right,
        ),
    ],
    layout: Split(
        direction: Vertical,
        panes: [
            (
                size: "4",
                pane: Split(
                    direction: Horizontal,
                    panes: [
                        (
                            size: "35",
                            borders: "LEFT | TOP | BOTTOM",
                            pane: Component("header_left")
                        ),
                        (
                            size: "100%",
                            borders: "TOP | BOTTOM",
                            pane: Component("header_center")
                        ),
                        (
                            size: "35",
                            borders: "RIGHT | TOP | BOTTOM",
                            pane: Component("header_right")
                        ),
                    ]
                )
            ),
            (
                pane: Pane(Empty()),
                size: "1",
            ),
            (
                pane: Pane(Tabs),
                borders: "TOP | BOTTOM",
                size: "3",
            ),
            (
                pane: Pane(TabContent),
                size: "100%",
            ),
            (
                size: "3",
                pane: Split(
                    direction: Horizontal,
                    panes: [
                        (
                            size: "100%",
                            borders: "ALL",
                            pane: Component("progress_bar"),
                        ),
                    ]
                ),
            ),
        ],
    ),
    components: {
        "state": Pane(Property(
            content: [
                (kind: Text("["), style: (fg: "#d6b11a", modifiers: "Bold")),
                (kind: Property(Status(StateV2( ))), style: (fg: "#d6b11a", modifiers: "Bold")),
                (kind: Text("]"), style: (fg: "#d6b11a", modifiers: "Bold")),
            ], align: Left,
        )),
        "title": Pane(Property(
            content: [
                (kind: Property(Song(Title)), style: (modifiers: "Bold"),
                    default: (kind: Text("No Song"), style: (modifiers: "Bold"))),
            ], align: Center, scroll_speed: 1
        )),
        "volume": Pane(Property(
            content: [
                 (kind: Text("Vol: "), style: (fg: "#d6b11a", modifiers: "Bold")),
                 (kind: Property(Status(Volume)), style: (fg: "#d6b11a", modifiers: "Bold")),
                 (kind: Text("% "), style: (fg: "#d6b11a", modifiers: "Bold"))
             ], align: Right,
        )),
        "elapsed": Pane(Property(
            content: [
                (kind: Property(Status(Elapsed))), 
                (kind: Text("/")), 
                (kind: Property(Status(Duration))), 
            ],
            align: Left,
        )),
        "artist": Pane(Property(
            content: [
                (kind: Property(Song(Artist)), style: (fg: "#d6b11a", modifiers: "Bold"),
                    default: (kind: Text("Unknown"), style: (fg: "#d6b11a", modifiers: "Bold"))),
            ], align: Center, scroll_speed: 1
        )),
        "states": Split(
            direction: Horizontal,
            panes: [
                (
                    size: "1",
                    pane: Pane(Empty())
                ),
                (
                    size: "100%",
                    pane: Pane(Property(content: [(kind: Property(Status(InputBuffer())), style: (fg: "#d6b11a"), align: Left)]))
                ),
                (
                    size: "6",
                    pane: Pane(Property(content: [
                        (kind: Text("["), style: (fg: "#d6b11a", modifiers: "Bold")),
                        (kind: Property(Status(RepeatV2(
                            on_label: "z",
                            off_label: "z",
                            on_style: (fg: "#7aa2f7", modifiers: "Bold"),
                            off_style: (fg: "#d6b11a", modifiers: "Dim"),
                        )))),
                        (kind: Property(Status(RandomV2(
                            on_label: "x",
                            off_label: "x",
                            on_style: (fg: "#7aa2f7", modifiers: "Bold"),
                            off_style: (fg: "#d6b11a", modifiers: "Dim"),
                        )))),
                        (kind: Property(Status(ConsumeV2(
                            on_label: "c",
                            off_label: "c",
                            oneshot_label: "c",
                            on_style: (fg: "#7aa2f7", modifiers: "Bold"),
                            off_style: (fg: "#d6b11a", modifiers: "Dim"),
                            oneshot_style: (fg: "#cfc9c2", modifiers: "Dim"),
                        )))),
                        (kind: Property(Status(SingleV2(
                            on_label: "v",
                            off_label: "v",
                            oneshot_label: "v",
                            on_style: (fg: "#7aa2f7", modifiers: "Bold"),
                            off_style: (fg: "#d6b11a", modifiers: "Dim"),
                            oneshot_style: (fg: "#cfc9c2", modifiers: "Bold"),
                        )))),
                        (kind: Text("]"), style: (fg: "#d6b11a", modifiers: "Bold")),
                        ],
                        align: Right
                    ))
                ),
            ]
        ),
        "header_left": Split(
            direction: Vertical,
            panes: [
                (size: "1", pane: Component("state")),
                (size: "1", pane: Component("elapsed")),
            ]
        ),
        "header_center": Split(
            direction: Vertical,
            panes: [
                (size: "1", pane: Component("title")),
                (size: "1", pane: Component("artist")),
            ]
        ),
        "header_right": Split(
            direction: Vertical,
            panes: [
                (size: "1", pane: Component("volume")),
                (size: "1", pane: Component("states")),
            ]
        ),
        "progress_bar": Split(
            direction: Horizontal,
            panes: [
                (
                    size: "1",
                    pane: Pane(Empty())
                ),
                (
                    size: "100%",
                    pane: Pane(ProgressBar)
                ),
                (
                    size: "1",
                    pane: Pane(Empty())
                ),
            ]
        )
    },
)
